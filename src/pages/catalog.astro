---
import Layout from '../layouts/Layout.astro';
import productsData from '../data/products.json';
import { relativeTime } from '../utils/relativeTime';
import { resizedImg } from '../utils/imgProxy';

interface Product {
  store: string;
  storeType: string;
  brand: string;
  material: string;
  color: string | null;
  weightKg: number | null;
  lengthM: number | null;
  diameterMm: number | null;
  pricePerSpool: number | null;
  pricePerKg: number | null;
  currency: string;
  sku: string | null;
  url: string;
  image: string | null;
  inStock: boolean | null;
  name: string | null;
  checkedAt?: string;
}

const data = productsData as { lastChecked: string; products: Product[]; stats: Record<string, { products: number }> };
const products = data.products;
const lastChecked = data.lastChecked;

const materials = [...new Set(products.map(p => p.material))].sort();
const brands = [...new Set(products.map(p => p.brand))].sort();
// Colours are sorted by how many products carry them (popular ones first),
// then alphabetically as a stable secondary key.
const colorCounts = new Map<string, number>();
for (const p of products) if (p.color) colorCounts.set(p.color, (colorCounts.get(p.color) ?? 0) + 1);
const colors = [...colorCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], 'uk'))
  .map(([c]) => c);
const storeCount = Object.keys(data.stats ?? {}).length;

// Strict-stock encoding: '1' = confirmed in-stock, '0' = confirmed OOS,
// '2' = unknown. The catalog hides anything other than '1' when the
// "Тільки в наявності" filter is on.
function stockCode(inStock: boolean | null): '0' | '1' | '2' {
  if (inStock === true) return '1';
  if (inStock === false) return '0';
  return '2';
}

// Show prices only when we have confirmed availability — otherwise the
// number may be stale (e.g. Monofilament keeps a historical price in
// JSON-LD on out-of-stock pages where the UI hides it).
function visiblePrice<T>(inStock: boolean | null, price: T): T | null {
  return inStock === true ? price : null;
}

// id → display name (best-effort: derived from companies.json convention)
const STORE_NAMES: Record<string, string> = {
  'plexiwire': 'Plexiwire',
  'lbl-corp': 'LBL Corp',
  'monofilament': 'Monofilament',
};

const SITE = 'https://3d-filament.pages.dev';

// SEO: ItemList structured data lets Google surface product cards
// with prices/availability in search results. Only emit entries we can
// fully back with confirmed in-stock + price — otherwise Google will
// flag stale prices and we don't want to mislead crawlers.
const seoProducts = products.filter(p => p.inStock === true && p.pricePerSpool).slice(0, 100);

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Каталог філаменту',
  numberOfItems: seoProducts.length,
  itemListElement: seoProducts.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: p.name ?? `${p.material} ${p.color ?? ''}`.trim(),
      url: p.url,
      image: p.image ?? undefined,
      sku: p.sku ?? undefined,
      brand: { '@type': 'Brand', name: p.brand },
      offers: {
        '@type': 'Offer',
        priceCurrency: p.currency,
        price: p.pricePerSpool,
        url: p.url,
        availability: 'https://schema.org/InStock',
      },
    },
  })),
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Головна', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Каталог філаменту', item: SITE + '/catalog/' },
  ],
};

const seoTitle = `Каталог філаменту України — ${products.length} товарів від ${storeCount} магазинів • ціни і наявність`;
const seoDescription = `Агрегатор пластиків для 3D-друку: ${[...new Set(products.map(p => p.material))].slice(0, 8).join(', ')} та інші. ${products.length} товарів від ${[...new Set(products.map(p => p.brand))].join(', ')}. Сортування за ціною за катушку та за кг, фільтри за матеріалом, кольором, брендом.`;

// Hex map for Ukrainian colour names. Falls back to a neutral grey on miss.
const COLOR_HEX: Record<string, string> = {
  'білий': '#ffffff',
  'натуральний': '#f5deb3',
  'жовтий': '#ffd400',
  'золото': '#d4af37',
  'помаранчевий': '#ff8c00',
  'червоний': '#d92020',
  'бордовий': '#800020',
  'рожевий': '#ff69b4',
  'фіолетовий': '#7b2cbf',
  'синій': '#1e3a8a',
  'блакитний': '#5cb6e6',
  'бірюзовий': '#1abc9c',
  'зелений': '#2e8b57',
  'салатовий': '#98e26b',
  'хакі': '#5d6634',
  'коричневий': '#8b4513',
  'бронза': '#cd7f32',
  'мідь': '#b87333',
  'срібло': '#c0c0c0',
  'сталь': '#71797e',
  'сірий': '#808080',
  'чорний': '#1a1a1a',
};
function colorHex(name: string): string {
  return COLOR_HEX[name.toLowerCase()] ?? '#999';
}
---

<Layout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(itemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
  <header class="catalog-header">
    <h1>Каталог філаменту</h1>
    <p class="subtitle">{products.length} товарів від {storeCount} {storeCount === 1 ? 'магазину' : 'магазинів'} • {relativeTime(lastChecked)}</p>
  </header>

  <div class="catalog-layout" id="catalogLayout">
    <aside class="catalog-sidebar" id="catalogSidebar" aria-label="Фільтри">
      <div class="sidebar-header">
        <h2 class="sidebar-title">Фільтри</h2>
        <button type="button" class="sidebar-close" id="sidebarClose" aria-label="Закрити фільтри">✕</button>
      </div>
      <div class="store-pill" id="storePill" hidden>
        <span>Магазин: <strong id="storePillName"></strong></span>
        <a href="/catalog" class="store-pill-clear" id="storePillClear" aria-label="Скинути фільтр магазину">✕</a>
      </div>
      <div class="filter-group">
        <label for="search">Пошук</label>
        <input type="text" id="search" placeholder="Назва, артикул, колір..." autocomplete="off" />
      </div>
      <div class="filter-group">
        <label for="materialFilter">Матеріал</label>
        <select id="materialFilter">
          <option value="all">Всі</option>
          {materials.map(m => <option value={m}>{m}</option>)}
        </select>
      </div>
      <div class="filter-group">
        <label for="brandFilter">Бренд</label>
        <select id="brandFilter">
          <option value="all">Всі</option>
          {brands.map(b => <option value={b}>{b}</option>)}
        </select>
      </div>
      <div class="filter-group">
        <label for="colorFilter">Колір</label>
        <details class="color-dropdown" id="colorDropdown">
          <summary id="colorSummary">
            <span class="swatch swatch-all" aria-hidden="true"></span>
            <span class="color-label">Всі</span>
          </summary>
          <div class="color-menu">
            <button type="button" class="color-option" data-value="all">
              <span class="swatch swatch-all" aria-hidden="true"></span>
              <span class="color-name">Всі</span>
            </button>
            {colors.map(c => (
              <button type="button" class="color-option" data-value={c}>
                <span class="swatch" style={`background:${colorHex(c)}`} aria-hidden="true"></span>
                <span class="color-name">{c}</span>
                <span class="color-count">{colorCounts.get(c)}</span>
              </button>
            ))}
          </div>
        </details>
        <input type="hidden" id="colorFilter" value="all" />
      </div>
      <div class="filter-group">
        <label for="sortFilter">Сортування</label>
        <select id="sortFilter">
          <option value="ppk_asc">Ціна за кг ↑</option>
          <option value="ppk_desc">Ціна за кг ↓</option>
          <option value="pps_asc">Ціна за катушку ↑</option>
          <option value="pps_desc">Ціна за катушку ↓</option>
          <option value="weight_asc">Вага ↑</option>
          <option value="weight_desc">Вага ↓</option>
          <option value="diameter_asc">Діаметр ↑</option>
          <option value="diameter_desc">Діаметр ↓</option>
          <option value="name_asc">Назва А→Я</option>
          <option value="name_desc">Назва Я→А</option>
          <option value="material_asc">Матеріал А→Я</option>
          <option value="brand_asc">Бренд А→Я</option>
        </select>
      </div>
      <div class="filter-group filter-stock">
        <label for="inStockOnly" class="checkbox-label">
          <input type="checkbox" id="inStockOnly" checked />
          Тільки в наявності
        </label>
      </div>
    </aside>

    <div class="sidebar-backdrop" id="sidebarBackdrop" hidden></div>

    <div class="catalog-main">

  <div class="results-bar">
    <div class="results-summary" id="resultsSummary"></div>
    <div class="view-toggle" role="tablist" aria-label="Режим перегляду">
      <button type="button" class="view-btn active" data-view="grid" aria-label="Сітка" title="Сітка">
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><rect x="0" y="0" width="7" height="7" rx="1"/><rect x="9" y="0" width="7" height="7" rx="1"/><rect x="0" y="9" width="7" height="7" rx="1"/><rect x="9" y="9" width="7" height="7" rx="1"/></svg>
        <span>Сітка</span>
      </button>
      <button type="button" class="view-btn" data-view="table" aria-label="Таблиця" title="Таблиця">
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><rect x="0" y="2" width="16" height="2" rx="0.5"/><rect x="0" y="7" width="16" height="2" rx="0.5"/><rect x="0" y="12" width="16" height="2" rx="0.5"/></svg>
        <span>Таблиця</span>
      </button>
    </div>
  </div>

  <table class="product-table" id="productTable" hidden>
    <thead>
      <tr>
        <th>Колір</th>
        <th class="sortable" data-sort="material">Матеріал</th>
        <th class="sortable" data-sort="brand">Бренд</th>
        <th class="sortable" data-sort="name">Назва</th>
        <th class="sortable num" data-sort="weight">Вага</th>
        <th class="sortable num" data-sort="diameter">Діам.</th>
        <th class="sortable num" data-sort="pps">Ціна, грн</th>
        <th class="sortable num" data-sort="ppk">Грн/кг</th>
        <th>Наявність</th>
      </tr>
    </thead>
    <tbody id="productTableBody">
      {products.map(p => {
        const code = stockCode(p.inStock);
        const pps = visiblePrice(p.inStock, p.pricePerSpool);
        const ppk = visiblePrice(p.inStock, p.pricePerKg);
        return (
        <tr
          class="product-row"
          data-material={p.material}
          data-brand={p.brand}
          data-store={p.store}
          data-color={p.color ?? ''}
          data-instock={code}
          data-name={(p.name ?? '').toLowerCase()}
          data-ppk={ppk ?? 0}
          data-pps={pps ?? 0}
          data-weight={p.weightKg ?? 0}
          data-diameter={p.diameterMm ?? 0}
          data-search={`${p.name ?? ''} ${p.sku ?? ''} ${p.color ?? ''} ${p.brand}`.toLowerCase()}
        >
          <td>
            <span class="row-color">
              {p.color && <span class="swatch swatch-sm" style={`background:${colorHex(p.color)}`} aria-hidden="true"></span>}
              <span>{p.color ?? '—'}</span>
            </span>
          </td>
          <td><span class="tag tag-material">{p.material}</span></td>
          <td>{p.brand}</td>
          <td><a class="row-link" href={p.url} target="_blank" rel="noopener noreferrer">{p.name ?? '—'}</a></td>
          <td>{p.weightKg ? `${p.weightKg} кг` : '—'}</td>
          <td>{p.diameterMm ? `${p.diameterMm} мм` : '—'}</td>
          <td class="num">{pps ?? '—'}</td>
          <td class="num">{ppk ?? '—'}</td>
          <td>
            {code === '1' && <span class="tag tag-in">В наявн.</span>}
            {code === '0' && <span class="tag tag-out">Немає</span>}
            {code === '2' && <span class="tag tag-unknown">Уточнюйте</span>}
          </td>
        </tr>
        );
      })}
    </tbody>
  </table>

  <div class="product-grid" id="productGrid">
    {products.map(p => {
      const code = stockCode(p.inStock);
      const pps = visiblePrice(p.inStock, p.pricePerSpool);
      const ppk = visiblePrice(p.inStock, p.pricePerKg);
      return (
      <article
        class="product-card"
        data-material={p.material}
        data-brand={p.brand}
        data-store={p.store}
        data-color={p.color ?? ''}
        data-instock={code}
        data-name={(p.name ?? '').toLowerCase()}
        data-ppk={ppk ?? 0}
        data-pps={pps ?? 0}
        data-weight={p.weightKg ?? 0}
        data-diameter={p.diameterMm ?? 0}
        data-search={`${p.name ?? ''} ${p.sku ?? ''} ${p.color ?? ''} ${p.brand}`.toLowerCase()}
      >
        <a class="product-card-link" href={p.url} target="_blank" rel="noopener noreferrer">
          {p.image && (
            <div class="product-image">
              <img src={resizedImg(p.image, 240, 240) ?? p.image} alt={p.name ?? p.material} loading="lazy" decoding="async" width="240" height="240" />
            </div>
          )}
          <div class="product-info">
            <div class="product-tags">
              <span class="tag tag-material">{p.material}</span>
              {p.color && <span class="tag tag-color">{p.color}</span>}
              {code === '0' && <span class="tag tag-out">Немає</span>}
              {code === '1' && <span class="tag tag-in">В наявності</span>}
              {code === '2' && <span class="tag tag-unknown">Уточнюйте</span>}
            </div>
            <h3 class="product-name">{p.name ?? `${p.material} ${p.color ?? ''}`}</h3>
            <div class="product-meta">
              <span>{p.brand}</span>
              {p.weightKg && <span>{p.weightKg}кг</span>}
              {p.diameterMm && <span>{p.diameterMm}мм</span>}
            </div>
            <div class="product-price">
              {pps !== null
                ? <span class="price-spool">{pps} {p.currency === 'UAH' ? 'грн' : p.currency}</span>
                : <span class="price-spool price-unknown">—</span>
              }
              {ppk !== null && <span class="price-kg">{ppk} грн/кг</span>}
            </div>
          </div>
        </a>
      </article>
      );
    })}
  </div>

  <div class="no-results" id="noResults" style="display:none">
    <h3>Нічого не знайдено</h3>
    <p>Спробуйте змінити фільтри.</p>
  </div>
    </div><!-- /.catalog-main -->
  </div><!-- /.catalog-layout -->

  <button type="button" class="filter-fab" id="filterFab" aria-label="Відкрити фільтри">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
    <span>Фільтри</span>
  </button>

  <script id="store-names-data" type="application/json" set:html={JSON.stringify(STORE_NAMES)}></script>
</Layout>

<style>
  .catalog-header {
    margin-bottom: 24px;
  }
  .catalog-header h1 {
    font-size: 2rem;
    margin: 0 0 8px;
    color: var(--color-text-primary);
  }
  .catalog-header .subtitle {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }
  .store-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
    padding: 6px 6px 6px 14px;
    background: var(--color-info-bg);
    border: 1px solid var(--color-info);
    color: var(--color-info);
    border-radius: 999px;
    font-size: 0.9rem;
  }
  .store-pill[hidden] { display: none; }
  .store-pill-clear {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--color-info);
    color: var(--color-bg-card);
    text-decoration: none;
    font-weight: 700;
    line-height: 1;
  }
  .store-pill-clear:hover { opacity: 0.85; }
  /* Two-column page layout with sticky filter sidebar.
     <1024px collapses to a single column; sidebar becomes a drawer. */
  .catalog-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 24px;
    align-items: start;
  }
  .catalog-sidebar {
    position: sticky;
    top: calc(var(--header-height) + 16px);
    align-self: start;
    max-height: calc(100vh - var(--header-height) - 32px);
    overflow-y: auto;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .sidebar-title { font-size: 1rem; color: var(--color-text-primary); margin: 0; }
  .sidebar-close {
    display: none; /* visible only on mobile drawer */
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    width: 32px; height: 32px;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: 1rem;
  }
  .sidebar-close:hover { color: var(--color-text-primary); }
  .catalog-main { min-width: 0; /* enables shrink so the table can scroll */ }
  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .filter-group label {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .filter-stock { margin-top: 4px; }
  .checkbox-label {
    display: inline-flex; align-items: center; gap: 8px;
    cursor: pointer; user-select: none;
    color: var(--color-text-primary);
    font-size: 0.95rem;
    padding: 4px 0;
  }
  .sidebar-backdrop {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 60;
  }
  .filter-fab {
    display: none; /* visible only on mobile */
    position: fixed; right: 18px; bottom: 18px;
    z-index: 55;
    align-items: center; gap: 8px;
    padding: 12px 18px;
    background: var(--color-accent);
    color: var(--color-bg-primary);
    border: none;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
    cursor: pointer;
  }
  .filter-fab:hover { transform: translateY(-1px); }
  @media (max-width: 1023px) {
    .catalog-layout { grid-template-columns: 1fr; }
    .catalog-sidebar {
      position: fixed;
      top: 0; left: 0;
      width: min(320px, 88vw);
      height: 100dvh;
      max-height: 100dvh;
      border-radius: 0;
      border-right: 1px solid var(--color-border);
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      z-index: 70;
    }
    .catalog-layout.is-drawer-open .catalog-sidebar { transform: translateX(0); }
    .catalog-layout.is-drawer-open .sidebar-backdrop { display: block; }
    .sidebar-close { display: inline-flex; align-items: center; justify-content: center; }
    .filter-fab { display: inline-flex; }
  }
  select, input[type="text"] {
    padding: 8px 12px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text-primary);
    font-size: 0.95rem;
    min-width: 140px;
  }
  .results-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    gap: 12px;
    flex-wrap: wrap;
  }
  .results-summary {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }
  .view-toggle {
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg-secondary);
  }
  .view-btn {
    display: inline-flex; align-items: center; gap: 6px;
    background: transparent;
    color: var(--color-text-secondary);
    border: 0;
    padding: 8px 14px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: background 0.15s, color 0.15s;
  }
  .view-btn + .view-btn { border-left: 1px solid var(--color-border); }
  .view-btn:hover { color: var(--color-text-primary); }
  .view-btn.active {
    background: var(--color-bg-card);
    color: var(--color-accent);
  }
  /* Color dropdown */
  /* Colour selector lives inline inside the sidebar — the menu flows below
     the summary as a static accordion instead of overflowing the column. */
  .color-dropdown { width: 100%; }
  .color-dropdown summary {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
    font-size: 0.95rem;
  }
  .color-dropdown summary::-webkit-details-marker { display: none; }
  .color-dropdown summary::after {
    content: '▾';
    margin-left: auto;
    color: var(--color-text-secondary);
    font-size: 0.7rem;
  }
  .color-dropdown[open] summary::after { transform: rotate(180deg); }
  .color-menu {
    margin-top: 6px;
    max-height: 280px;
    overflow-y: auto;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 6px;
    box-shadow: 0 6px 16px rgba(0,0,0,0.15);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .color-option {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    background: transparent;
    border: 0;
    padding: 6px 8px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    color: var(--color-text-primary);
    font-size: 0.9rem;
    text-align: left;
  }
  .color-option:hover { background: var(--color-bg-secondary); }
  .color-option.active { background: var(--color-info-bg); color: var(--color-info); }
  .swatch {
    display: inline-block;
    width: 16px; height: 16px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .swatch-sm { width: 12px; height: 12px; }
  .swatch-all {
    background: conic-gradient(#d92020, #ffd400, #2e8b57, #1e3a8a, #7b2cbf, #d92020);
  }
  /* Table */
  .product-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    font-size: 0.9rem;
  }
  .product-table th, .product-table td {
    padding: 10px 12px;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }
  .product-table thead th {
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    font-weight: 600;
    font-size: 0.85rem;
    position: sticky; top: 0;
  }
  .product-table th.sortable {
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  .product-table th.sortable:hover { color: var(--color-text-primary); }
  .product-table th.sortable::after {
    content: '⇅';
    margin-left: 6px;
    opacity: 0.35;
    font-size: 0.85em;
  }
  .product-table th.is-sorted-asc::after { content: '↑'; opacity: 1; color: var(--color-accent); }
  .product-table th.is-sorted-desc::after { content: '↓'; opacity: 1; color: var(--color-accent); }
  .product-table tbody tr:hover { background: var(--color-bg-card); }
  .product-table tbody tr:last-child td { border-bottom: 0; }
  .product-table .num { text-align: right; font-variant-numeric: tabular-nums; }
  .row-color {
    display: inline-flex; align-items: center; gap: 8px;
  }
  .row-link {
    color: var(--color-text-primary);
    text-decoration: none;
  }
  .row-link:hover { color: var(--color-info); text-decoration: underline; }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }
  /* HTML [hidden] gets clobbered by display:grid/table on the class —
     restore the visibility-control behaviour. */
  .product-grid[hidden], .product-table[hidden] { display: none; }
  .product-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.15s, border-color 0.15s;
  }
  .product-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-info);
  }
  .product-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }
  .product-image {
    aspect-ratio: 1 / 1;
    background: var(--color-bg-card);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .product-image img {
    width: 100%; height: 100%;
    object-fit: contain;
  }
  .product-info {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .tag {
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
  }
  .tag-material {
    background: var(--color-info-bg);
    color: var(--color-info);
    border-color: var(--color-info);
    font-weight: 600;
  }
  .tag-in {
    background: var(--color-success-bg);
    color: var(--color-success);
    border-color: var(--color-success);
  }
  .tag-out {
    background: var(--color-danger-bg);
    color: var(--color-danger);
    border-color: var(--color-danger);
  }
  .tag-unknown {
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    border-color: var(--color-border);
    font-style: italic;
  }
  .price-unknown { color: var(--color-text-secondary); font-weight: 500; }
  .color-name { flex: 1; }
  .color-count {
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }
  .color-option.active .color-count { color: inherit; opacity: 0.7; }
  .product-name {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-text-primary);
    font-weight: 500;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.3;
    min-height: 2.6em;
  }
  .product-meta {
    display: flex; flex-wrap: wrap; gap: 8px;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }
  .product-price {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: auto;
    padding-top: 6px;
    border-top: 1px solid var(--color-border);
  }
  .price-spool {
    font-size: 1.1rem;
    color: var(--color-text-primary);
    font-weight: 600;
  }
  .price-kg {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }
  .no-results {
    text-align: center;
    padding: 60px 20px;
    color: var(--color-text-secondary);
  }
</style>

<script>
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.product-card'));
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.product-row'));
  const grid = document.getElementById('productGrid')!;
  const table = document.getElementById('productTable') as HTMLTableElement;
  const tableBody = document.getElementById('productTableBody')!;
  const noResults = document.getElementById('noResults')!;
  const summary = document.getElementById('resultsSummary')!;
  const search = document.getElementById('search') as HTMLInputElement;
  const materialF = document.getElementById('materialFilter') as HTMLSelectElement;
  const brandF = document.getElementById('brandFilter') as HTMLSelectElement;
  const colorF = document.getElementById('colorFilter') as HTMLInputElement;
  const sortF = document.getElementById('sortFilter') as HTMLSelectElement;
  const inStockOnly = document.getElementById('inStockOnly') as HTMLInputElement;
  const colorDropdown = document.getElementById('colorDropdown') as HTMLDetailsElement;
  const colorSummary = document.getElementById('colorSummary')!;
  const viewBtns = document.querySelectorAll<HTMLButtonElement>('.view-btn');
  const storePill = document.getElementById('storePill')!;
  const storePillName = document.getElementById('storePillName')!;
  let currentView: 'grid' | 'table' = (localStorage.getItem('catalogView') as 'grid' | 'table') || 'grid';
  let currentStore: string = 'all';
  const storeDisplayNames: Record<string, string> = JSON.parse(document.getElementById('store-names-data')?.textContent ?? '{}');

  // Restore from URL
  const params = new URLSearchParams(window.location.search);
  if (params.get('material')) materialF.value = params.get('material')!;
  if (params.get('brand')) brandF.value = params.get('brand')!;
  if (params.get('color')) {
    colorF.value = params.get('color')!;
    syncColorSummary();
  }
  if (params.get('sort')) sortF.value = params.get('sort')!;
  if (params.get('q')) search.value = params.get('q')!;
  if (params.get('instock') === '0') inStockOnly.checked = false;
  if (params.get('view') === 'table') currentView = 'table';
  if (params.get('store')) {
    currentStore = params.get('store')!;
    syncStorePill();
  }
  applyView();

  function syncStorePill() {
    if (currentStore === 'all') {
      storePill.hidden = true;
    } else {
      storePill.hidden = false;
      storePillName.textContent = storeDisplayNames[currentStore] ?? currentStore;
    }
  }

  function applyView() {
    grid.hidden = currentView !== 'grid';
    table.hidden = currentView !== 'table';
    viewBtns.forEach(b => b.classList.toggle('active', b.dataset.view === currentView));
    localStorage.setItem('catalogView', currentView);
  }
  viewBtns.forEach(b => b.addEventListener('click', () => {
    currentView = b.dataset.view as 'grid' | 'table';
    applyView();
    updateUrl();
  }));

  function syncColorSummary() {
    const v = colorF.value;
    const opt = colorDropdown.querySelector<HTMLButtonElement>(`.color-option[data-value="${CSS.escape(v)}"]`);
    if (!opt) return;
    colorSummary.innerHTML = opt.innerHTML;
    colorDropdown.querySelectorAll('.color-option').forEach(o => o.classList.toggle('active', o === opt));
  }

  colorDropdown.querySelectorAll<HTMLButtonElement>('.color-option').forEach(opt => {
    opt.addEventListener('click', () => {
      colorF.value = opt.dataset.value!;
      syncColorSummary();
      colorDropdown.open = false;
      apply();
    });
  });
  syncColorSummary();
  // Close dropdown when clicking outside
  document.addEventListener('click', e => {
    if (!colorDropdown.contains(e.target as Node)) colorDropdown.open = false;
  });

  function updateUrl() {
    const p = new URLSearchParams();
    if (materialF.value !== 'all') p.set('material', materialF.value);
    if (brandF.value !== 'all') p.set('brand', brandF.value);
    if (colorF.value !== 'all') p.set('color', colorF.value);
    if (sortF.value !== 'ppk_asc') p.set('sort', sortF.value);
    if (search.value) p.set('q', search.value);
    if (!inStockOnly.checked) p.set('instock', '0');
    if (currentView === 'table') p.set('view', 'table');
    if (currentStore !== 'all') p.set('store', currentStore);
    window.history.replaceState({}, '', window.location.pathname + (p.toString() ? '?' + p.toString() : ''));
  }

  function matches(el: HTMLElement, q: string, mat: string, brand: string, color: string, store: string, onlyInStock: boolean) {
    if (mat !== 'all' && el.dataset.material !== mat) return false;
    if (brand !== 'all' && el.dataset.brand !== brand) return false;
    if (color !== 'all' && el.dataset.color !== color) return false;
    if (store !== 'all' && el.dataset.store !== store) return false;
    // Strict: "Тільки в наявності" shows only confirmed in-stock items
    // (data-instock === '1'). Unknown ('2') and confirmed OOS ('0') hide.
    if (onlyInStock && el.dataset.instock !== '1') return false;
    if (q && !(el.dataset.search ?? '').includes(q)) return false;
    return true;
  }

  // Numeric sort keys map to a dataset attribute; price sorts push "no
  // visible price" entries (0) to the bottom of ascending lists via 9e9.
  const NUMERIC_KEYS: Record<string, string> = {
    pps: 'pps', ppk: 'ppk', weight: 'weight', diameter: 'diameter',
  };
  const STRING_KEYS: Record<string, string> = {
    name: 'name', material: 'material', brand: 'brand', color: 'color',
  };

  function compareFn(sortKey: string) {
    return (a: HTMLElement, b: HTMLElement) => {
      const m = sortKey.match(/^(.+)_(asc|desc)$/);
      if (!m) return 0;
      const [, key, dir] = m;
      const sign = dir === 'asc' ? 1 : -1;

      if (key in NUMERIC_KEYS) {
        const ds = NUMERIC_KEYS[key];
        const av = Number(a.dataset[ds] ?? 0);
        const bv = Number(b.dataset[ds] ?? 0);
        // Push 0 (== missing/masked) to the end regardless of direction
        if (av === 0 && bv !== 0) return 1;
        if (bv === 0 && av !== 0) return -1;
        return sign * (av - bv);
      }
      if (key in STRING_KEYS) {
        const ds = STRING_KEYS[key];
        const av = a.dataset[ds] ?? '';
        const bv = b.dataset[ds] ?? '';
        return sign * av.localeCompare(bv, 'uk');
      }
      return 0;
    };
  }

  function apply() {
    const q = search.value.trim().toLowerCase();
    const mat = materialF.value;
    const brand = brandF.value;
    const color = colorF.value;
    const onlyInStock = inStockOnly.checked;
    const cmp = compareFn(sortF.value);

    const visibleCards = cards.filter(c => matches(c, q, mat, brand, color, currentStore, onlyInStock)).sort(cmp);
    cards.forEach(c => { c.style.display = 'none'; });
    visibleCards.forEach(c => { c.style.display = ''; grid.appendChild(c); });

    const visibleRows = rows.filter(r => matches(r, q, mat, brand, color, currentStore, onlyInStock)).sort(cmp);
    rows.forEach(r => { r.style.display = 'none'; });
    visibleRows.forEach(r => { r.style.display = ''; tableBody.appendChild(r); });

    const n = visibleCards.length;
    summary.textContent = `Знайдено ${n} ${n === 1 ? 'товар' : n < 5 ? 'товари' : 'товарів'}`;
    noResults.style.display = n === 0 ? '' : 'none';
    if (n === 0) { grid.hidden = true; table.hidden = true; }
    else applyView();
    syncSortIndicators();
    updateUrl();
  }

  // Update the ↑/↓ glyph on the sortable table headers to mirror sortF.value.
  function syncSortIndicators() {
    const m = sortF.value.match(/^(.+)_(asc|desc)$/);
    const activeKey = m ? m[1] : null;
    const activeDir = m ? m[2] : null;
    document.querySelectorAll<HTMLElement>('th.sortable').forEach(th => {
      const k = th.dataset.sort;
      th.classList.toggle('is-sorted-asc', k === activeKey && activeDir === 'asc');
      th.classList.toggle('is-sorted-desc', k === activeKey && activeDir === 'desc');
    });
  }

  // Click on a sortable <th> toggles its column's direction in sortF; the
  // select stays the canonical source of truth.
  document.querySelectorAll<HTMLElement>('th.sortable').forEach(th => {
    th.addEventListener('click', () => {
      const k = th.dataset.sort;
      if (!k) return;
      const cur = sortF.value;
      const [curKey, curDir] = cur.split('_');
      const nextDir = curKey === k && curDir === 'asc' ? 'desc' : 'asc';
      const candidate = `${k}_${nextDir}`;
      // Only switch if option exists; otherwise pick the default direction
      // we wrote into the select for that column.
      const exists = [...sortF.options].some(o => o.value === candidate);
      sortF.value = exists ? candidate : (
        [...sortF.options].find(o => o.value.startsWith(k + '_'))?.value ?? cur
      );
      apply();
    });
  });

  search.addEventListener('input', apply);
  materialF.addEventListener('change', apply);
  brandF.addEventListener('change', apply);
  colorF.addEventListener('change', apply);
  sortF.addEventListener('change', apply);
  inStockOnly.addEventListener('change', apply);
  document.getElementById('storePillClear')?.addEventListener('click', e => {
    e.preventDefault();
    currentStore = 'all';
    syncStorePill();
    apply();
  });

  // Mobile drawer: FAB opens, backdrop / close button / ESC closes.
  const layout = document.getElementById('catalogLayout')!;
  const fab = document.getElementById('filterFab');
  const closeBtn = document.getElementById('sidebarClose');
  const backdrop = document.getElementById('sidebarBackdrop')!;
  function openDrawer() {
    layout.classList.add('is-drawer-open');
    backdrop.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    layout.classList.remove('is-drawer-open');
    backdrop.hidden = true;
    document.body.style.overflow = '';
  }
  fab?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && layout.classList.contains('is-drawer-open')) closeDrawer();
  });

  apply();
</script>
